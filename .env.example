# Supabase (capa de persistencia — packages/kos-persistence)
VITE_SUPABASE_URL=https://tu-proyecto.supabase.co
VITE_SUPABASE_ANON_KEY=tu_anon_key

# OpenRouter (provider router — packages/kos-capability-runtime)
# ⚠️ Nunca expongas esta clave en el frontend. Debe usarse solo desde un backend/proxy.
OPENROUTER_API_KEY=sk-or-xxxx
